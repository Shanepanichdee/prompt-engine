# ── Which provider to use ──────────────────────────────────────────────────
# Options: openai | anthropic | gemini | github
AI_PROVIDER=openai

# ── OpenAI ─────────────────────────────────────────────────────────────────
# Get key: https://platform.openai.com/api-keys
# Pay per use. gpt-4o-mini ≈ $0.001 per call.
OPENAI_API_KEY=sk-...

# ── Anthropic (Claude) ─────────────────────────────────────────────────────
# Get key: https://console.anthropic.com
# Pay per use. Free credits on signup. Best reasoning quality.
ANTHROPIC_API_KEY=sk-ant-...

# ── Google Gemini ──────────────────────────────────────────────────────────
# Get key: https://aistudio.google.com/apikey  (free — 1,500 requests/day)
# gemini-1.5-flash is free with generous limits.
GEMINI_API_KEY=AIza...

# ── GitHub Models (free, no subscription needed) ───────────────────────────
# Get token: https://github.com/settings/tokens → generate classic token (no scopes needed)
# Runs GPT-4o, Llama 3, Mistral, Phi, and more — all free with rate limits.
# Note: "GitHub Copilot" is the IDE extension. "GitHub Models" is this API.
GITHUB_TOKEN=github_pat_...
